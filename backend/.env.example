# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zk_solvency

# Redis
REDIS_URL=redis://localhost:6379

# StarkNet
STARKNET_RPC_URL=http://127.0.0.1:5050
STARKNET_PRIVATE_KEY=0x...
STARKNET_ACCOUNT_ADDRESS=0x...

# Contract Addresses (StarkNet)
NULLIFIER_REGISTRY_ADDRESS=0x...
SOLVENCY_VERIFIER_ADDRESS=0x...
PROOF_REGISTRY_ADDRESS=0x...

# Prover
PROVER_ADAPTER=sp1
MOCK_PROVER=true
PROVER_API_URL=https://api.succinct.xyz/api/v1/prover
PROVER_API_KEY=your_succinct_api_key

# Authentication
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
X402_GATEWAY_SECRET=your_x402_gateway_secret

# Proof Scheduling
PROOF_INTERVAL_MS=600000

# Server
PORT=3001
NODE_ENV=development

# Exchange
EXCHANGE_ID=your_exchange_id
ZKTL_SECRET_KEY=your_zktls_attestation_secret