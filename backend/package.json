{
  "name": "zk-solvency-backend",
  "version": "1.0.0",
  "description": "ZK-Solvency backend - privacy-preserving proof-of-reserves system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bullmq": "^5.4.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "ethers": "^6.12.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "starknet": "^6.17.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.21.4",
    "pg": "^8.11.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
