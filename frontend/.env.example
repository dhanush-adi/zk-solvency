# ZK-Solvency Frontend Environment Variables

# Backend API Configuration
# Point to your ZK-Solvency backend server
# Default: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Wallet Integration
# WalletConnect Project ID for Web3 wallet connections
# Get one at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_ID=

# Smart Contract Addresses
# USDC contract address for payment verification
# Ethereum Mainnet: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=

# Feature Flags
# Enable Server-Sent Events for real-time proof updates
# Default: true
NEXT_PUBLIC_ENABLE_SSE=true

# Enable wallet connection features
# Default: true
NEXT_PUBLIC_ENABLE_WALLET=true
