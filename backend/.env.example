# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zk_solvency

# Redis
REDIS_URL=redis://localhost:6379

# Blockchain (Ethereum Sepolia)
CHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_wallet_private_key

# Contract Addresses (Sepolia)
NULLIFIER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000001
VERIFIER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000002
PROOF_CHAIN_ADDRESS=0x0000000000000000000000000000000000000003

# Prover Network (Succinct SP1)
PROVER_API_URL=https://api.succinct.xyz/api/v1/prover
PROVER_API_KEY=your_succinct_api_key

# Authentication
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
X402_GATEWAY_SECRET=your_x402_gateway_secret

# Proof Scheduling
PROOF_INTERVAL_MS=600000

# Server
PORT=3001
NODE_ENV=development

# Exchange
EXCHANGE_ID=your_exchange_id
ZKTL_SECRET_KEY=your_zktls_attestation_secret