# ── StarkNet Configuration ─────────────────────────────────────────────
# Local devnet (default)
STARKNET_RPC_URL=http://127.0.0.1:5050

# For Sepolia testnet:
# STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io

# Account credentials (use devnet predeployed accounts for local dev)
STARKNET_PRIVATE_KEY=0x...
STARKNET_ACCOUNT_ADDRESS=0x...

# ── Layer 4 Contract ───────────────────────────────────────────────────
NULLIFIER_REGISTRY_ADDRESS=0x...

# ── Layer 5 Prover Configuration ───────────────────────────────────────
# Prover adapter: 'sp1' (primary) or 'stark' (secondary)
PROVER_ADAPTER=sp1

# Set to 'true' for local dev without SP1 toolchain
MOCK_PROVER=true

# Proof generation interval (ms, default 10 min)
CYCLE_INTERVAL_MS=600000

# ── Layer 6 Contracts ──────────────────────────────────────────────────
SOLVENCY_VERIFIER_ADDRESS=0x...
PROOF_REGISTRY_ADDRESS=0x...
